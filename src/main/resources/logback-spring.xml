<?xml version="1.0" encoding="UTF-8"?>
<!--
    logback-spring.xml — Cấu hình Logback theo Spring Profile
    <springProfile> cho phép tách config hoàn toàn dev / prod
-->
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ── Properties ── -->
    <property name="LOG_FILE" value="logs/employee-management.log"/>
    <property name="APP_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
    <property name="CONSOLE_PATTERN_DEV"
              value="%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{30}) - %msg%n"/>

    <!-- ════════════════════════════════════════════ -->
    <!--  PROFILE: dev                                -->
    <!-- ════════════════════════════════════════════ -->
    <springProfile name="dev">

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_PATTERN_DEV}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- App code: DEBUG (thấy toàn bộ luồng xử lý) -->
        <logger name="com.example.employeemanagement" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <!-- Hibernate SQL: thấy query được sinh ra -->
        <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <!-- Hibernate bind params: thấy giá trị ? trong query -->
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <!-- Spring Web: thấy request mapping -->
        <logger name="org.springframework.web" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <!-- Root: WARN — giảm noise từ thư viện bên thứ 3 -->
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>

    </springProfile>

    <!-- ════════════════════════════════════════════ -->
    <!--  PROFILE: prod                               -->
    <!-- ════════════════════════════════════════════ -->
    <springProfile name="prod">

        <!-- Console: format đầy đủ timestamp -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${APP_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- File: Rolling theo ngày + size -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}</file>
            <encoder>
                <pattern>${APP_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/employee-management-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <!-- Async: không block main thread khi ghi file -->
        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <appender-ref ref="FILE"/>
        </appender>

        <!-- App code: INFO -->
        <logger name="com.example.employeemanagement" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>

        <!-- Hibernate: WARN — tắt SQL log ở prod -->
        <logger name="org.hibernate" level="WARN" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>

        <!-- Spring Security: WARN -->
        <logger name="org.springframework.security" level="WARN" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>

        <!-- Root: INFO -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>

    </springProfile>

</configuration>